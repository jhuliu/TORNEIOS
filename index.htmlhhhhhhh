/* ── HELPERS ── */
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
function catStyle(c){return CAT_STYLE[c]||'background:#f0f0f0;color:#555'}
function roundStyle(r){return ROUND_STYLE[r]||'background:#E8F5E9;color:#2E7D32'}
function isFinal(r){return r==='FINAL'}
function getTimeBlocks(matches){
  const b={};
  matches.forEach((m,i)=>{if(!b[m.time])b[m.time]=[];b[m.time].push({...m,idx:i})});
  return b;
}

/* ── SYNC STATUS ── */
function showSync(msg,type){
  const el=document.getElementById('syncStatus');
  el.textContent=msg; el.className='sync-bar sync-'+type; el.style.display='flex';
  if(type==='ok') setTimeout(()=>{el.style.display='none'},3000);
}

/* ── PERSIST via Firebase ── */
async function persist(){
  const payload = {data, heroConfig};
  const json = JSON.stringify(payload);
  localStorage.setItem('tennisData', json);
  try{
    showSync('Salvando para todos…','loading');
    const r = await fetch(FB_URL, {
      method: 'PUT',
      headers: {'Content-Type': 'application/json'},
      body: json
    });
    if(r.ok) showSync('✅ Salvo — todos verão agora','ok');
    else showSync('⚠️ Erro ao salvar ('+r.status+')','err');
  }catch(e){
    showSync('⚠️ Sem conexão — salvo só localmente','err');
  }
}

/* ── LOAD via Firebase ── */
async function loadData(){
  function applyPayload(p){
    if(!p) return false;
    if(Array.isArray(p)){data=p;return true;}
    if(p.data && Array.isArray(p.data)){
      data=p.data;
      if(p.heroConfig) heroConfig=p.heroConfig;
      return true;
    }
    return false;
  }
  try{
    const r = await fetch(FB_URL+'?t='+Date.now());
    if(r.ok){
      const txt = await r.text();
      if(txt && txt!=='null'){
        const p = JSON.parse(txt);
        if(applyPayload(p)) return;
      }
    }
  }catch(e){}
  // fallback localStorage
  const saved = localStorage.getItem('tennisData');
  if(saved){try{applyPayload(JSON.parse(saved));}catch(e){}}
}

// Polling — jogadores veem atualizações a cada 15s
setInterval(async()=>{
  if(isAdmin) return;
  try{
    const r = await fetch(FB_URL+'?t='+Date.now());
    if(r.ok){
      const txt = await r.text();
      if(txt && txt!=='null'){
        const p = JSON.parse(txt);
        if(Array.isArray(p)){data=p;}
        else if(p&&p.data&&Array.isArray(p.data)){
          data=p.data;
          if(p.heroConfig) heroConfig=p.heroConfig;
        }
        renderAll();
      }
    }
  }catch(e){}
},15000);

/* ── RENDER ── */
function renderScore(m,di,mi){
  if(isAdmin){
    if(m.score) return`<span class="score-display" onclick="startEdit(${di},${mi})">${esc(m.score)}</span>`;
    return`<span class="score-pending" onclick="startEdit(${di},${mi})">+ placar</span>`;
  }
  if(m.score) return`<span class="score-display" style="cursor:default">${esc(m.score)}</span>`;
  return`<span class="score-pending" style="cursor:default;pointer-events:none">a definir</span>`;
}

function renderDay(di){
  const d=data[di];
  const blocks=getTimeBlocks(d.matches);
  const editTourBtn=isAdmin?`<button class="tour-edit-btn" onclick="openTourModal(${di})">✏️ Editar</button>`:'';
  let html=`<div class="tour-header">
    <div class="tour-header-left">
      <div class="tour-icon">🎾</div>
      <div><div class="tour-name">${esc(d.tour)}</div><div class="tour-meta">${esc(d.meta)}</div></div>
    </div>
    <div class="tour-pills">
      <span class="pill pill-green">${esc(d.pill)}</span>
      <span class="pill pill-gold">${esc(d.date)}</span>
      ${editTourBtn}
    </div>
  </div>`;

  if(!Object.keys(blocks).length) html+=`<div class="empty-day">Nenhum jogo cadastrado neste dia.</div>`;

  Object.keys(blocks).sort().forEach(time=>{
    html+=`<div class="time-block"><div class="time-row"><div class="time-dot"></div><span class="time-txt">⏰ ${time}</span><div class="time-line"></div></div>`;
    blocks[time].forEach(m=>{
      const fin=isFinal(m.round)?' final-match':'';
      const courtLabel=m.court?`· Q${esc(m.court)}`:'';
      const adminBtns=isAdmin
        ?`<button class="edit-pencil" onclick="openInlineEdit(${di},${m.idx})" title="Editar">✏️</button>
           <button class="del-btn" onclick="askDelete(${di},${m.idx})" title="Excluir">✕</button>`
        :'<span></span>';
      html+=`<div class="match${fin}" id="match-${di}-${m.idx}">
        <div class="meta">
          <span class="rbadge" style="${roundStyle(m.round)}">${esc(m.round)}</span>
          <span class="cbadge" style="${catStyle(m.cat)}">${esc(m.cat)}</span>
          ${isAdmin?`<button class="edit-pencil" onclick="openInlineEdit(${di},${m.idx})" title="Editar">✏️</button>`:''}
        </div>
        <div class="player-col pleft">
          <div class="pname">${esc(m.p1)}</div>
          <div class="pnum">J${esc(m.num)} ${courtLabel}</div>
        </div>
        <div class="vs"><div class="vs-circle">VS</div></div>
        <div class="player-col pright">
          <div class="pname">${esc(m.p2)}</div>
        </div>
        <div class="score-area" id="score-${di}-${m.idx}">${renderScore(m,di,m.idx)}</div>
        ${isAdmin?`<button class="del-btn" onclick="askDelete(${di},${m.idx})" title="Excluir">✕</button>`:'<span></span>'}
      </div>
      <div id="inline-edit-${di}-${m.idx}" style="display:none"></div>`;
    });
    html+='</div>';
  });

  if(isAdmin) html+=`<button class="add-match-btn" onclick="openAddModal(${di})">+ Adicionar jogo</button>`;
  document.getElementById('day'+di).innerHTML=html;
}

/* ── RENDER TABS (dynamic) ── */
function renderTabs(){
  const container = document.getElementById('dayTabsContainer');
  const contentsEl = document.getElementById('dayContents');

  // Build tabs
  let tabsHtml = '';
  data.forEach((d,i)=>{
    const label = d.tabLabel || (d.date+' — '+d.pill);
    tabsHtml += `<div class="day-tab${i===currentDay?' active':''}" onclick="showDay(${i},this)">${esc(label)}</div>`;
  });
  if(isAdmin){
    tabsHtml += `<div class="day-tab day-tab-add" onclick="openNewDayModal()" title="Adicionar novo dia">＋ Novo dia</div>`;
  }
  container.innerHTML = tabsHtml;

  // Build day content divs
  let contentsHtml = '';
  data.forEach((_,i)=>{
    contentsHtml += `<div id="day${i}" class="day-content${i===currentDay?' active':''}"></div>`;
  });
  contentsEl.innerHTML = contentsHtml;
}

/* ── RENDER HERO ── */
function renderHero(){
  document.getElementById('heroTag').textContent = heroConfig.tag||'';
  document.getElementById('heroTitle').textContent = heroConfig.title||'';
  document.getElementById('heroSub').textContent = heroConfig.sub||'';
  document.getElementById('heroEditBtn').style.display = isAdmin ? 'inline-block' : 'none';
}

function renderAll(){
  renderHero();
  renderTabs();
  for(let i=0;i<data.length;i++) renderDay(i);
  updateStats();
}

function updateStats(){
  let total=0,done=0;
  const cats=new Set();
  data.forEach(d=>d.matches.forEach(m=>{total++;if(m.score)done++;if(m.cat)cats.add(m.cat);}));
  document.getElementById('statGames').textContent=total;
  document.getElementById('statDone').textContent=done;
  document.getElementById('statCats').textContent=cats.size||'—';
  document.getElementById('statDays').textContent=data.length;
}

/* ── SCORE EDIT ── */
function startEdit(di,mi){
  const sa=document.getElementById('score-'+di+'-'+mi);
  const cur=data[di].matches[mi].score||'';
  sa.innerHTML=`<div class="score-input-wrap">
    <input class="score-input" id="sinput" type="text" value="${esc(cur)}" placeholder="6/3 6/2" autofocus>
    <button class="score-save" onclick="saveScore(${di},${mi})">OK</button>
    <button class="score-cancel" onclick="cancelEdit(${di},${mi})">✕</button>
  </div>`;
  setTimeout(()=>{const i=document.getElementById('sinput');if(i){i.focus();i.select();}},50);
}
function saveScore(di,mi){
  const i=document.getElementById('sinput');if(!i)return;
  data[di].matches[mi].score=i.value.trim();
  renderDay(di);updateStats();persist();
}
function cancelEdit(di,mi){
  document.getElementById('score-'+di+'-'+mi).innerHTML=renderScore(data[di].matches[mi],di,mi);
}

/* ── INLINE EDIT ── */
function openInlineEdit(di,mi){
  const m=data[di].matches[mi];
  const c=document.getElementById('inline-edit-'+di+'-'+mi);
  const catOpts=['10M','11M','8M','10F','11F','12M','12F','14M','14F','16M']
    .map(v=>`<option${v===m.cat?' selected':''}>${v}</option>`).join('');
  const rndOpts=['1ª RODADA','OITAVAS','QUARTAS','SEMI','SEMIFINAL','FINAL','TT']
    .map(v=>`<option${v===m.round?' selected':''}>${v}</option>`).join('');
  c.innerHTML=`<div class="inline-edit-row">
    <div class="full"><label>Jogador A</label><input id="ie_p1_${di}_${mi}" type="text" value="${esc(m.p1)}"></div>
    <div class="full"><label>Jogador B</label><input id="ie_p2_${di}_${mi}" type="text" value="${esc(m.p2)}"></div>
    <div><label>Horário</label><input id="ie_time_${di}_${mi}" type="time" value="${esc(m.time)}"></div>
    <div><label>Quadra</label><input id="ie_court_${di}_${mi}" type="text" value="${esc(m.court||'')}"></div>
    <div><label>Categoria</label><select id="ie_cat_${di}_${mi}">${catOpts}</select></div>
    <div><label>Rodada</label><select id="ie_round_${di}_${mi}">${rndOpts}</select></div>
    <div class="full"><label>Placar</label><input id="ie_score_${di}_${mi}" type="text" value="${esc(m.score||'')}"></div>
    <div class="full inline-actions">
      <button class="btn-cancel-inline" onclick="closeInlineEdit(${di},${mi})">Cancelar</button>
      <button class="btn-save-inline" onclick="saveInlineEdit(${di},${mi})">Salvar alterações</button>
    </div>
  </div>`;
  c.style.display='block';
  c.scrollIntoView({behavior:'smooth',block:'nearest'});
}
function closeInlineEdit(di,mi){
  const c=document.getElementById('inline-edit-'+di+'-'+mi);
  if(c){c.style.display='none';c.innerHTML='';}
}
function saveInlineEdit(di,mi){
  const g=id=>document.getElementById(id);
  const m=data[di].matches[mi];
  m.p1=g(`ie_p1_${di}_${mi}`).value.trim()||m.p1;
  m.p2=g(`ie_p2_${di}_${mi}`).value.trim()||m.p2;
  m.time=g(`ie_time_${di}_${mi}`).value||m.time;
  m.court=g(`ie_court_${di}_${mi}`).value.trim();
  m.cat=g(`ie_cat_${di}_${mi}`).value;
  m.round=g(`ie_round_${di}_${mi}`).value;
  m.score=g(`ie_score_${di}_${mi}`).value.trim();
  renderDay(di);updateStats();persist();
}

/* ── DELETE ── */
function askDelete(di,mi){
  pendingDelete={di,mi};
  const m=data[di].matches[mi];
  document.getElementById('confirmText').textContent=
    `Excluir o jogo ${m.num}: ${m.p1} vs ${m.p2}? Esta ação não pode ser desfeita.`;
  document.getElementById('confirmModal').style.display='block';
}
function closeConfirm(){document.getElementById('confirmModal').style.display='none';pendingDelete=null;}
function confirmDelete(){
  if(!pendingDelete)return;
  const{di,mi}=pendingDelete;
  data[di].matches.splice(mi,1);
  closeConfirm();renderDay(di);updateStats();persist();
}

/* ── ADD ── */
function openAddModal(di){addingDay=di;document.getElementById('addModal').style.display='block';}
function closeModal(){document.getElementById('addModal').style.display='none';}
function saveNewMatch(){
  const p1=document.getElementById('inp_p1').value.trim();
  const p2=document.getElementById('inp_p2').value.trim();
  if(!p1||!p2){alert('Preencha os dois jogadores');return;}
  data[addingDay].matches.push({
    time:document.getElementById('inp_time').value,
    cat:document.getElementById('inp_cat').value,
    round:document.getElementById('inp_round').value,
    num:data[addingDay].matches.length+1,
    p1,p2,
    court:document.getElementById('inp_court').value.trim(),
    score:document.getElementById('inp_score').value.trim()
  });
  closeModal();renderDay(addingDay);updateStats();persist();
}

/* ── AUTH ── */
function setMode(mode){
  if(mode==='edit'){
    document.getElementById('mainContent').style.display='none';
    document.getElementById('lockScreen').style.display='block';
    document.getElementById('pwInput').value='';
    document.getElementById('lockError').style.display='none';
  } else {
    isAdmin=false;
    document.getElementById('btnView').classList.add('active');
    document.getElementById('btnEdit').classList.remove('active');
    document.getElementById('editHint').style.display='none';
    document.getElementById('publicBar').style.display='block';
    renderAll();
  }
}
function checkPw(){
  if(document.getElementById('pwInput').value===ADMIN_PW){
    isAdmin=true;
    document.getElementById('lockScreen').style.display='none';
    document.getElementById('mainContent').style.display='flex';
    document.getElementById('mainContent').style.flexDirection='column';
    document.getElementById('btnEdit').classList.add('active');
    document.getElementById('btnView').classList.remove('active');
    document.getElementById('editHint').style.display='block';
    document.getElementById('publicBar').style.display='none';
    renderAll();
  } else {
    document.getElementById('lockError').style.display='block';
    document.getElementById('pwInput').value='';
  }
}

/* ── TABS ── */
function showDay(idx,el){
  currentDay=idx;
  document.querySelectorAll('.day-content').forEach(d=>d.classList.remove('active'));
  const dc=document.getElementById('day'+idx);
  if(dc) dc.classList.add('active');
  document.querySelectorAll('.day-tab').forEach(t=>t.classList.remove('active'));
  if(el) el.classList.add('active');
}

/* ── SHARE ── */
function copyLink(){
  const url=location.href;
  document.getElementById('shareUrl').textContent=url;
  navigator.clipboard.writeText(url).then(()=>{
    const b=document.querySelector('.copy-btn');
    b.textContent='Copiado!';setTimeout(()=>b.textContent='Copiar link',2000);
  });
}

/* ── HERO MODAL ── */
function openHeroModal(){
  document.getElementById('hm_tag').value=heroConfig.tag||'';
  document.getElementById('hm_title').value=heroConfig.title||'';
  document.getElementById('hm_sub').value=heroConfig.sub||'';
  document.getElementById('heroModal').style.display='block';
}
function closeHeroModal(){document.getElementById('heroModal').style.display='none';}
function saveHeroModal(){
  heroConfig.tag=document.getElementById('hm_tag').value.trim()||heroConfig.tag;
  heroConfig.title=document.getElementById('hm_title').value.trim()||heroConfig.title;
  heroConfig.sub=document.getElementById('hm_sub').value.trim();
  closeHeroModal();
  renderHero();
  persist();
}

/* ── NEW DAY MODAL ── */
function openNewDayModal(){document.getElementById('newDayModal').style.display='block';}
function closeNewDayModal(){document.getElementById('newDayModal').style.display='none';}
function saveNewDay(){
  const tab=document.getElementById('nd_tab').value.trim();
  const tour=document.getElementById('nd_tour').value.trim();
  const meta=document.getElementById('nd_meta').value.trim();
  const pill=document.getElementById('nd_pill').value.trim();
  const date=document.getElementById('nd_date').value.trim();
  if(!tab){alert('Digite o nome da aba');return;}
  data.push({
    tabLabel:tab,
    tour:tour||tab,
    meta:meta||'',
    pill:pill||'',
    date:date||'',
    matches:[]
  });
  currentDay=data.length-1;
  closeNewDayModal();
  // clear inputs
  ['nd_tab','nd_tour','nd_meta','nd_pill','nd_date'].forEach(id=>document.getElementById(id).value='');
  renderAll();
  persist();
}

/* ── TOUR MODAL ── */
let editingTourDay=0;
function openTourModal(di){
  editingTourDay=di;
  const d=data[di];
  const defaultLabel=d.date&&d.pill?(d.date+' — '+d.pill):'';
  document.getElementById('tm_tab').value=d.tabLabel||defaultLabel;
  document.getElementById('tm_tour').value=d.tour||'';
  document.getElementById('tm_meta').value=d.meta||'';
  document.getElementById('tm_pill').value=d.pill||'';
  document.getElementById('tm_date').value=d.date||'';
  document.getElementById('tourModal').style.display='block';
}
function closeTourModal(){document.getElementById('tourModal').style.display='none';}
function saveTourModal(){
  const d=data[editingTourDay];
  const tab=document.getElementById('tm_tab').value.trim();
  const t=document.getElementById('tm_tour').value.trim();
  const m=document.getElementById('tm_meta').value.trim();
  const p=document.getElementById('tm_pill').value.trim();
  const dt=document.getElementById('tm_date').value.trim();
  if(tab) d.tabLabel=tab;
  if(t) d.tour=t;
  d.meta=m;
  if(p) d.pill=p;
  if(dt) d.date=dt;
  closeTourModal();
  renderAll();
  persist();
}

/* ── INIT ── */
document.getElementById('shareUrl').textContent=location.href;
loadData().then(()=>renderAll());
</script>
</body>
</html>
