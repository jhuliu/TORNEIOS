<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🎾 Circuito Kidstour 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
html{font-size:16px}
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#1A6B30;--green-dark:#0C3318;--green-mid:#155226;--green-light:#E6F4EA;
  --gold:#D4A842;--gold-dark:#A07820;--gold-light:#FDF5DC;
  --red:#C0392B;--red-light:#FEF0EE;
  --radius:12px;--border:#E2E8E2;
  --shadow:0 2px 8px rgba(0,0,0,.08);
  --shadow-lg:0 4px 20px rgba(0,0,0,.12)
}
body{font-family:'Inter',system-ui,sans-serif;background:#EFF3EF;color:#1a1a1a;-webkit-font-smoothing:antialiased}
.app{min-height:100vh;display:flex;flex-direction:column}

/* ── TOPBAR ── */
.topbar{background:var(--green-dark);padding:0 16px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.25)}
.topbar-left{display:flex;align-items:center;gap:10px}
.fpt-badge{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--gold),#E8C060);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--green-dark);flex-shrink:0;box-shadow:0 2px 6px rgba(0,0,0,.2)}
.topbar-title{color:#fff;font-size:13px;font-weight:500;font-family:'Oswald',sans-serif;letter-spacing:.5px}
.topbar-right{display:flex;align-items:center;gap:6px}
.mode-btn{padding:7px 14px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;border:none;transition:all .18s;letter-spacing:.3px}
.btn-view{background:rgba(255,255,255,.12);color:rgba(255,255,255,.85)}
.btn-edit{background:var(--gold);color:var(--green-dark)}
.btn-view.active{background:rgba(255,255,255,.25);color:#fff}
.btn-edit.active{background:#E8C040;box-shadow:0 2px 8px rgba(212,168,66,.4)}

/* ── LOCK ── */
.lock-screen{background:linear-gradient(160deg,var(--green-dark) 0%,var(--green-mid) 100%);display:flex;align-items:center;justify-content:center;padding:60px 20px;min-height:100vh}
.lock-card{background:#fff;border-radius:20px;padding:36px 28px;width:100%;max-width:340px;text-align:center;box-shadow:var(--shadow-lg)}
.lock-icon{width:56px;height:56px;border-radius:50%;background:var(--green-light);margin:0 auto 18px;display:flex;align-items:center;justify-content:center}
.lock-icon svg{width:26px;height:26px;stroke:var(--green);fill:none;stroke-width:2}
.lock-card h2{font-size:17px;font-weight:600;margin-bottom:4px;font-family:'Oswald',sans-serif;letter-spacing:.3px}
.lock-card p{font-size:13px;color:#999;margin-bottom:22px}
.lock-card input{width:100%;padding:12px 14px;border:1.5px solid #e0e0e0;border-radius:10px;font-size:18px;text-align:center;letter-spacing:6px;margin-bottom:14px;outline:none;transition:border-color .15s}
.lock-card input:focus{border-color:var(--green)}
.lock-card button{width:100%;padding:12px;background:var(--green);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Oswald',sans-serif;letter-spacing:.5px}
.lock-error{color:var(--red);font-size:12px;margin-top:8px;display:none}

/* ── HERO ── */
.hero{background:linear-gradient(160deg,var(--green-dark) 0%,var(--green-mid) 60%,#1E7535 100%);padding:24px 16px 20px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'🎾';position:absolute;right:-10px;top:50%;transform:translateY(-50%);font-size:110px;opacity:.06;pointer-events:none}
.hero-tag{display:inline-block;background:rgba(212,168,66,.2);border:1px solid rgba(212,168,66,.5);color:var(--gold);font-size:10px;font-weight:600;padding:3px 12px;border-radius:20px;letter-spacing:1px;margin-bottom:10px;font-family:'Oswald',sans-serif}
.hero h1{color:#fff;font-size:20px;font-weight:700;line-height:1.25;margin-bottom:4px;font-family:'Oswald',sans-serif;letter-spacing:.3px}
.hero-sub{color:rgba(255,255,255,.5);font-size:12px;margin-bottom:16px}
.hero-stats{display:flex;justify-content:center;background:rgba(255,255,255,.08);border-radius:12px;overflow:hidden;max-width:380px;margin:0 auto;border:1px solid rgba(255,255,255,.1)}
.hstat{flex:1;padding:10px 6px;text-align:center;border-right:1px solid rgba(255,255,255,.1)}
.hstat:last-child{border-right:none}
.hstat-num{color:var(--gold);font-size:22px;font-weight:700;font-family:'Oswald',sans-serif}
.hstat-label{color:rgba(255,255,255,.4);font-size:9px;letter-spacing:.6px;margin-top:2px;text-transform:uppercase}

/* ── TABS ── */
.day-tabs{display:flex;overflow-x:auto;background:#fff;border-bottom:2px solid var(--border);padding:0 10px;-webkit-overflow-scrolling:touch;scrollbar-width:none}
.day-tabs::-webkit-scrollbar{display:none}
.day-tab{flex-shrink:0;padding:13px 14px;font-size:11px;font-weight:600;color:#999;border-bottom:2.5px solid transparent;cursor:pointer;white-space:nowrap;transition:all .14s;letter-spacing:.2px;text-transform:uppercase;font-family:'Oswald',sans-serif}
.day-tab:hover{color:var(--green)}
.day-tab.active{color:var(--green);border-bottom-color:var(--green)}

/* ── CONTENT ── */
.content{flex:1;padding:14px 12px 36px;max-width:820px;margin:0 auto;width:100%}
.day-content{display:none}
.day-content.active{display:block}

.edit-hint{background:var(--gold-light);border:1px solid rgba(212,168,66,.35);border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:12px;color:#8B6914;display:flex;align-items:center;gap:8px}

.sync-bar{font-size:12px;padding:9px 14px;margin-bottom:12px;border-radius:10px;display:none;align-items:center;gap:8px}
.sync-ok{background:#E6F4EA;color:#1E7535;border:1px solid #B7DFC0}
.sync-err{background:#FEF0EE;color:#C0392B;border:1px solid #FACAC5}
.sync-loading{background:#EBF4FF;color:#1A5FAB;border:1px solid #BAD5F7}

/* ── TOUR HEADER ── */
.tour-header{background:#fff;border-radius:var(--radius);border:1px solid var(--border);padding:14px 16px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;box-shadow:var(--shadow)}
.tour-header-left{display:flex;align-items:center;gap:12px;flex:1;min-width:0}
.tour-icon{width:40px;height:40px;border-radius:10px;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.tour-name{font-size:14px;font-weight:700;color:var(--green-dark);font-family:'Oswald',sans-serif;letter-spacing:.2px}
.tour-meta{font-size:11px;color:#aaa;margin-top:2px}
.tour-pills{display:flex;gap:6px;flex-wrap:wrap;align-items:center}
.pill{padding:4px 10px;border-radius:20px;font-size:9px;font-weight:700;letter-spacing:.5px;text-transform:uppercase}
.pill-green{background:var(--green-light);color:var(--green)}
.pill-gold{background:var(--gold-light);color:var(--gold-dark)}
.tour-edit-btn{background:none;border:1px solid var(--border);border-radius:8px;padding:5px 10px;font-size:11px;color:#888;cursor:pointer;white-space:nowrap;transition:all .12s;display:flex;align-items:center;gap:4px}
.tour-edit-btn:hover{border-color:var(--green);color:var(--green);background:var(--green-light)}

/* ── TIME BLOCK ── */
.time-block{margin-bottom:20px}
.time-row{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.time-dot{width:8px;height:8px;border-radius:50%;background:var(--gold);flex-shrink:0}
.time-txt{font-size:12px;font-weight:700;color:#666;letter-spacing:.8px;font-family:'Oswald',sans-serif}
.time-line{flex:1;height:1px;background:linear-gradient(to right,#ddd,transparent)}

/* ── MATCH CARD ── */
.match{
  background:#fff;
  border-radius:var(--radius);
  border:1px solid var(--border);
  padding:12px 12px;
  margin-bottom:8px;
  display:grid;
  grid-template-columns:62px 1fr 28px 1fr 94px 30px;
  align-items:center;
  gap:6px;
  box-shadow:var(--shadow);
  transition:border-color .15s,box-shadow .15s
}
.match:hover{border-color:#C8D9C8;box-shadow:0 3px 10px rgba(0,0,0,.1)}
.match.final-match{border-color:var(--gold);background:linear-gradient(to right,#FFFDF0,#fff);box-shadow:0 2px 10px rgba(212,168,66,.2)}

.meta{display:flex;flex-direction:column;gap:3px;align-items:flex-start}
.rbadge{padding:2px 6px;border-radius:5px;font-size:8.5px;font-weight:700;text-align:center;white-space:nowrap;line-height:1.6;letter-spacing:.3px;font-family:'Oswald',sans-serif}
.cbadge{padding:2px 5px;border-radius:4px;font-size:8.5px;font-weight:700;text-align:center;line-height:1.6;font-family:'Oswald',sans-serif}
.edit-pencil{background:none;border:none;cursor:pointer;font-size:13px;padding:2px 3px;color:#d0d0d0;line-height:1;border-radius:4px;transition:all .12s}
.edit-pencil:hover{color:var(--green);background:#E6F4EA}

/* ── PLAYERS aligned on same row ── */
.player-col{display:flex;align-items:center;gap:4px;min-width:0}
.pleft{justify-content:flex-end}
.pright{justify-content:flex-start}
.pname{font-size:12.5px;font-weight:600;color:#1a1a1a;line-height:1.2;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pnum{font-size:9px;color:#ccc;flex-shrink:0;font-family:'Oswald',sans-serif}

.vs{display:flex;align-items:center;justify-content:center}
.vs-circle{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,#f0f0f0,#e8e8e8);border:1px solid #ddd;display:flex;align-items:center;justify-content:center;font-size:7.5px;font-weight:700;color:#aaa;flex-shrink:0;font-family:'Oswald',sans-serif}

.score-area{text-align:center}
.score-display{font-size:11.5px;font-weight:700;color:var(--red);background:var(--red-light);border:1px solid #F5C6C2;padding:4px 7px;border-radius:8px;display:inline-block;cursor:pointer;white-space:nowrap;font-family:'Oswald',sans-serif}
.score-display:hover{border-color:var(--red);box-shadow:0 1px 4px rgba(192,57,43,.2)}
.score-pending{font-size:10.5px;color:#d0d0d0;font-style:italic;cursor:pointer;padding:4px 7px;border:1px dashed #ddd;border-radius:8px;display:inline-block;white-space:nowrap}
.score-pending:hover{border-color:#aaa;color:#aaa}
.score-input-wrap{display:flex;gap:4px;align-items:center;justify-content:center}
.score-input{width:80px;padding:4px 6px;border:1.5px solid var(--green);border-radius:7px;font-size:12px;text-align:center;outline:none}
.score-save{padding:5px 8px;background:var(--green);color:#fff;border:none;border-radius:6px;font-size:11px;cursor:pointer;font-weight:600}
.score-cancel{padding:5px 6px;background:#f0f0f0;color:#666;border:none;border-radius:6px;font-size:11px;cursor:pointer}

.del-btn{width:28px;height:28px;border:none;background:transparent;color:#ddd;border-radius:6px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:all .12s;flex-shrink:0}
.del-btn:hover{background:#FEF0EE;color:var(--red)}

/* ── INLINE EDIT ── */
.inline-edit-row{background:#F3FBF5;border:1.5px solid var(--green);border-radius:var(--radius);padding:14px;margin-bottom:8px;display:grid;grid-template-columns:1fr 1fr;gap:10px}
.inline-edit-row .full{grid-column:1/-1}
.inline-edit-row label{font-size:11px;color:#666;display:block;margin-bottom:3px;font-weight:600;text-transform:uppercase;letter-spacing:.3px}
.inline-edit-row input,.inline-edit-row select{width:100%;padding:8px 10px;border:1px solid #ccc;border-radius:7px;font-size:13px;outline:none;background:#fff}
.inline-edit-row input:focus,.inline-edit-row select:focus{border-color:var(--green)}
.inline-actions{grid-column:1/-1;display:flex;gap:8px;margin-top:2px}
.btn-save-inline{flex:1;padding:9px;background:var(--green);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer}
.btn-cancel-inline{padding:9px 16px;background:#f0f0f0;color:#666;border:none;border-radius:8px;font-size:13px;cursor:pointer}

/* ── MODALS ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:flex-end;justify-content:center;padding:0;z-index:200}
@media(min-width:520px){.modal-overlay{align-items:center;padding:20px}}
.modal{background:#fff;border-radius:20px 20px 0 0;padding:28px 20px 32px;width:100%;max-width:420px;max-height:92vh;overflow-y:auto}
@media(min-width:520px){.modal{border-radius:16px;padding:26px 22px}}
.modal-handle{width:40px;height:4px;background:#e0e0e0;border-radius:2px;margin:0 auto 20px}
@media(min-width:520px){.modal-handle{display:none}}
.modal h3{font-size:16px;font-weight:700;margin-bottom:16px;font-family:'Oswald',sans-serif;letter-spacing:.3px}
.modal label{font-size:11px;color:#888;display:block;margin-bottom:4px;margin-top:14px;font-weight:600;text-transform:uppercase;letter-spacing:.4px}
.modal input,.modal select{width:100%;padding:10px 12px;border:1.5px solid #e0e0e0;border-radius:9px;font-size:13px;outline:none;transition:border-color .15s}
.modal input:focus,.modal select:focus{border-color:var(--green)}
.modal-footer{display:flex;gap:8px;margin-top:20px}
.modal-footer button{flex:1;padding:11px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:'Oswald',sans-serif;letter-spacing:.3px}
.btn-cancel{background:#f0f0f0;color:#777}
.btn-confirm{background:var(--green);color:#fff}
.btn-delete-confirm{background:var(--red);color:#fff}

.add-match-btn{width:100%;padding:11px;border:1.5px dashed #ccc;border-radius:var(--radius);background:transparent;color:#bbb;font-size:12px;font-weight:600;cursor:pointer;margin-top:8px;transition:all .14s;letter-spacing:.3px}
.add-match-btn:hover{border-color:var(--green);color:var(--green);background:var(--green-light)}

/* ── SHARE BAR ── */
.view-public-bar{background:#fff;border-top:1px solid var(--border);padding:16px;text-align:center}
.view-public-bar p{font-size:12px;color:#aaa;margin-bottom:8px}
.share-link{background:#F5F7F5;border:1px solid #ddd;border-radius:9px;padding:8px 12px;font-size:11px;color:#666;font-family:monospace;margin-bottom:10px;word-break:break-all}
.copy-btn{padding:9px 22px;background:var(--green);color:#fff;border:none;border-radius:9px;font-size:12px;cursor:pointer;font-weight:600;font-family:'Oswald',sans-serif;letter-spacing:.4px}

.empty-day{text-align:center;padding:48px 20px;color:#ccc;font-size:13px}
.empty-day::before{content:'🎾';display:block;font-size:40px;margin-bottom:12px;opacity:.4}

/* ── MOBILE ── */
@media(max-width:560px){
  .match{
    grid-template-columns:56px 1fr 24px 1fr;
    grid-template-rows:auto auto;
    padding:10px 10px;
    gap:5px
  }
  .score-area{grid-column:1/3;justify-self:center;margin-top:6px}
  .del-btn{grid-column:3/5;justify-self:end;align-self:end}
  .pname{font-size:12px}
  .hero h1{font-size:18px}
  .topbar-title{font-size:12px}
}
.day-tab-add{color:var(--gold)!important;border-bottom-color:transparent!important;font-style:normal}
.day-tab-add:hover{color:var(--gold-dark)!important;background:var(--gold-light)}
</style>
</head>
<body>
<div class="app" id="app">

<div class="topbar">
  <div class="topbar-left">
    <div class="fpt-badge">FPT</div>
    <span class="topbar-title">Circuito Kidstour 2026</span>
  </div>
  <div class="topbar-right">
    <button class="mode-btn btn-view active" id="btnView" onclick="setMode('view')">Jogadores</button>
    <button class="mode-btn btn-edit" id="btnEdit" onclick="setMode('edit')">Árbitro</button>
  </div>
</div>

<div id="lockScreen" style="display:none">
  <div class="lock-screen">
    <div class="lock-card">
      <div class="lock-icon">
        <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <h2>Área do árbitro</h2>
      <p>Digite a senha para editar resultados</p>
      <input type="password" id="pwInput" placeholder="••••" maxlength="6" onkeydown="if(event.key==='Enter')checkPw()">
      <button onclick="checkPw()">Entrar</button>
      <div class="lock-error" id="lockError">Senha incorreta. Tente novamente.</div>
    </div>
  </div>
</div>

<div id="mainContent">
  <div class="hero" id="heroSection">
    <div class="hero-tag" id="heroTag">CIRCUITO OFICIAL FPT</div>
    <h1 id="heroTitle">RR Tênis · Kidstour 2026</h1>
    <p class="hero-sub" id="heroSub">17 a 19 de Abril · Academia RR Tênis, São Paulo</p>
    <div class="hero-stats">
      <div class="hstat"><div class="hstat-num" id="statGames">—</div><div class="hstat-label">JOGOS</div></div>
      <div class="hstat"><div class="hstat-num" id="statDone">—</div><div class="hstat-label">CONCLUÍDOS</div></div>
      <div class="hstat"><div class="hstat-num" id="statCats">—</div><div class="hstat-label">CATEGORIAS</div></div>
      <div class="hstat"><div class="hstat-num" id="statDays">—</div><div class="hstat-label">DIAS</div></div>
    </div>
    <button id="heroEditBtn" onclick="openHeroModal()" style="display:none;margin-top:12px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:#fff;padding:7px 16px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;font-family:Oswald,sans-serif;letter-spacing:.5px">✏️ EDITAR CABEÇALHO</button>
  </div>

  <div class="day-tabs" id="dayTabsContainer"></div>

  <div class="content">
    <div id="editHint" style="display:none">
      <div class="edit-hint">✏️ &nbsp;Modo árbitro — <strong>lápis</strong> para editar jogadores/horário, <strong>placar</strong> para registrar resultado, <strong>✕</strong> para excluir.</div>
    </div>
    <div id="syncStatus" class="sync-bar"></div>
    <div id="dayContents"></div>
  </div>

  <div class="view-public-bar" id="publicBar">
    <p>Link para compartilhar com os jogadores:</p>
    <div class="share-link" id="shareUrl"></div>
    <button class="copy-btn" onclick="copyLink()">Copiar link</button>
  </div>
</div>

<!-- ADD MODAL -->
<div id="addModal" style="display:none">
  <div class="modal-overlay" onclick="if(event.target===this)closeModal()">
    <div class="modal">
      <div class="modal-handle"></div>
      <h3>➕ Adicionar jogo</h3>
      <label>Jogador A</label><input type="text" id="inp_p1" placeholder="Nome do jogador A">
      <label>Jogador B</label><input type="text" id="inp_p2" placeholder="Nome do jogador B">
      <label>Horário</label><input type="time" id="inp_time" value="14:00">
      <label>Quadra (opcional)</label><input type="text" id="inp_court" placeholder="ex: 3">
      <label>Categoria</label>
      <select id="inp_cat">
        <option>10M</option><option>11M</option><option>8M</option><option>10F</option>
        <option>11F</option><option>12M</option><option>12F</option><option>14M</option>
        <option>14F</option><option>16M</option>
      </select>
      <label>Rodada</label>
      <select id="inp_round">
        <option>1ª RODADA</option><option>OITAVAS</option><option>QUARTAS</option>
        <option>SEMI</option><option>SEMIFINAL</option><option>FINAL</option><option>TT</option>
      </select>
      <label>Placar (opcional)</label><input type="text" id="inp_score" placeholder="ex: 6/3 6/2">
      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeModal()">Cancelar</button>
        <button class="btn-confirm" onclick="saveNewMatch()">Salvar</button>
      </div>
    </div>
  </div>
</div>

<!-- CONFIRM DELETE -->
<div id="confirmModal" style="display:none">
  <div class="modal-overlay" onclick="if(event.target===this)closeConfirm()">
    <div class="modal" style="max-width:320px;text-align:center">
      <div class="modal-handle"></div>
      <h3>🗑️ Excluir jogo?</h3>
      <p id="confirmText" style="font-size:13px;color:#666;margin:12px 0 20px"></p>
      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeConfirm()">Cancelar</button>
        <button class="btn-delete-confirm" onclick="confirmDelete()">Excluir</button>
      </div>
    </div>
  </div>
</div>

<!-- HERO EDIT MODAL -->
<div id="heroModal" style="display:none">
  <div class="modal-overlay" onclick="if(event.target===this)closeHeroModal()">
    <div class="modal">
      <div class="modal-handle"></div>
      <h3>🏆 Editar Cabeçalho</h3>
      <label>Tag / circuito (ex: CIRCUITO OFICIAL FPT)</label><input type="text" id="hm_tag" placeholder="CIRCUITO OFICIAL FPT">
      <label>Título principal</label><input type="text" id="hm_title" placeholder="RR Tênis · Kidstour 2026">
      <label>Subtítulo (datas e local)</label><input type="text" id="hm_sub" placeholder="17 a 19 de Abril · Academia RR Tênis">
      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeHeroModal()">Cancelar</button>
        <button class="btn-confirm" onclick="saveHeroModal()">Salvar</button>
      </div>
    </div>
  </div>
</div>

<!-- NEW DAY MODAL -->
<div id="newDayModal" style="display:none">
  <div class="modal-overlay" onclick="if(event.target===this)closeNewDayModal()">
    <div class="modal">
      <div class="modal-handle"></div>
      <h3>📅 Adicionar Novo Dia</h3>
      <label>Nome da aba (ex: 20 Abr — Final)</label><input type="text" id="nd_tab" placeholder="20 Abr — Final">
      <label>Nome do torneio</label><input type="text" id="nd_tour" placeholder="Ex: Circuito Kidstour – RR Tênis">
      <label>Árbitro e local</label><input type="text" id="nd_meta" placeholder="Ex: Árbitro: João · Academia XYZ">
      <label>Fase / rótulo</label><input type="text" id="nd_pill" placeholder="Ex: Final">
      <label>Data</label><input type="text" id="nd_date" placeholder="Ex: 20 Abr 2026">
      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeNewDayModal()">Cancelar</button>
        <button class="btn-confirm" onclick="saveNewDay()">Criar dia</button>
      </div>
    </div>
  </div>
</div>

<!-- TOUR SETTINGS MODAL -->
<div id="tourModal" style="display:none">
  <div class="modal-overlay" onclick="if(event.target===this)closeTourModal()">
    <div class="modal">
      <div class="modal-handle"></div>
      <h3>⚙️ Configurações do Torneio</h3>
      <label>Nome da aba (ex: 17 Abr — 1ª Rodada)</label><input type="text" id="tm_tab" placeholder="Ex: 17 Abr — 1ª Rodada">
      <label>Nome do torneio</label><input type="text" id="tm_tour" placeholder="Ex: Circuito Kidstour – RR Tênis">
      <label>Árbitro e local</label><input type="text" id="tm_meta" placeholder="Ex: Árbitro: João · Academia XYZ">
      <label>Fase / rótulo</label><input type="text" id="tm_pill" placeholder="Ex: 1ª Rodada">
      <label>Data</label><input type="text" id="tm_date" placeholder="Ex: 17 Abr 2026">
      <div class="modal-footer">
        <button class="btn-cancel" onclick="closeTourModal()">Cancelar</button>
        <button class="btn-confirm" onclick="saveTourModal()">Salvar</button>
      </div>
    </div>
  </div>
</div>

</div>

